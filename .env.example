SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# PostgreSQL
DB_NAME=sportrent
DB_USER=sportrent
DB_PASSWORD=sportrent
DB_HOST=127.0.0.1
DB_PORT=5432
# DB_CONN_MAX_AGE=60

# Redis (channel layer для WebSocket)
REDIS_URL=redis://127.0.0.1:6379/0

# MongoDB (логи приложения и чат-сообщения)
MONGO_URL=mongodb://127.0.0.1:27017/
MONGO_DB=sportrent_logs

# Groq AI (бесплатный LLM для AI-поиска)
# Получить ключ: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Yandex Geocoder (серверное геокодирование: город → координаты)
# Получить ключ: https://developer.tech.yandex.ru/ → раздел "Геокодер"
YANDEX_GEOCODER_KEY=your-yandex-geocoder-key-here

# Yandex Maps JS API (отображение карты в браузере, React-фронт)
# Может быть тот же ключ или другой — зависит от настроек проекта в developer.tech.yandex.ru
YANDEX_MAPS_KEY=your-yandex-maps-api-key-here

# CORS (разрешённые origins для React dev-сервера)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173