SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# PostgreSQL
DB_NAME=sportrent
DB_USER=sportrent
DB_PASSWORD=sportrent
DB_HOST=127.0.0.1
DB_PORT=5432
# DB_CONN_MAX_AGE=60

# Redis (channel layer для WebSocket + кэш геолокации)
REDIS_URL=redis://127.0.0.1:6379/0

# MongoDB (логи приложения и чат-сообщения)
MONGO_URL=mongodb://127.0.0.1:27017/
MONGO_DB=sportrent_logs

# GigaChat (российский LLM для AI-поиска, Сбер Studio)
# Получить ключ: https://developers.sber.ru/studio → Проекты → API-ключи
GIGACHAT_CREDENTIALS=your-gigachat-credentials-here
# gigachat | regex  (на защите — gigachat, при разработке — regex чтобы не сжигать токены)
LLM_PROVIDER=gigachat
# True → в DEBUG режиме всегда использовать regex, GigaChat не вызывается
USE_REGEX_FALLBACK_IN_DEBUG=True

# Yandex Geocoder (серверное геокодирование: город → координаты)
# Получить ключ: https://developer.tech.yandex.ru/ → раздел "Геокодер"
YANDEX_GEOCODER_KEY=your-yandex-geocoder-key-here

# Yandex Maps JS API (отображение карты в браузере)
YANDEX_MAPS_KEY=your-yandex-maps-api-key-here

# ЮКасса (онлайн-оплата)
# Получить: https://yookassa.ru/ → Настройки → API
YOOKASSA_SHOP_ID=your-shop-id-here
YOOKASSA_SECRET_KEY=your-secret-key-here
# test | live
YOOKASSA_MODE=test

# Tuna/ngrok туннель (нужен только для webhook-ов ЮКассы в dev)
# Обновляй при каждом перезапуске тоннеля
TUNNEL_URL=https://your-tunnel.tuna.am
CSRF_TRUSTED_ORIGINS=https://your-tunnel.tuna.am
