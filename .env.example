SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# PostgreSQL
DB_NAME=sportrent
DB_USER=sportrent
DB_PASSWORD=sportrent
DB_HOST=127.0.0.1
DB_PORT=5432
# DB_CONN_MAX_AGE=60

# Redis (channel layer для WebSocket)
REDIS_URL=redis://127.0.0.1:6379/0

# MongoDB (логи приложения и чат-сообщения)
MONGO_URL=mongodb://127.0.0.1:27017/
MONGO_DB=sportrent_logs

# Groq AI (бесплатный LLM для AI-поиска)
# Получить ключ: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here